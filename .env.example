# =============================================================
# Sales Portal - Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored.
# This file (.env.example) IS committed — keep it secret-free.
# =============================================================

# -------------------------------------------------------------
# Database (Neon PostgreSQL or any Postgres)
# Get connection string from: https://neon.tech
# For serverless add: ?connection_limit=5&pool_timeout=10
# -------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional: restricted DB role without BYPASSRLS — enables full RLS enforcement.
# See docs/rls-setup.md for how to create this role in Neon.
# Without this, RLS policies are defined but not enforced (table owner bypasses).
DATABASE_URL_RLS=""

# -------------------------------------------------------------
# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters
# -------------------------------------------------------------
JWT_SECRET="your-jwt-secret-at-least-32-chars-long"

# -------------------------------------------------------------
# Email Service (Resend - https://resend.com)
# EMAIL_FROM must be a verified sender domain in Resend
# -------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@yourdomain.com"

# -------------------------------------------------------------
# Receipt Storage (Supabase - https://supabase.com)
# Required for PDF receipt upload/storage feature
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# -------------------------------------------------------------
# Application URL (no trailing slash)
# Used for email links and CORS origin checks
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# -------------------------------------------------------------
# CORS (optional)
# Comma-separated additional allowed origins
# -------------------------------------------------------------
# ALLOWED_ORIGINS="https://app.yourdomain.com,https://admin.yourdomain.com"

# -------------------------------------------------------------
# Cron Job Secret (optional)
# Protects /api/admin/cleanup from unauthenticated calls
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------------------------
# CRON_SECRET="change-me"

# -------------------------------------------------------------
# Redis Feature Flag Cache (optional - Upstash)
# If omitted, falls back to per-instance in-memory cache
# Create free DB at: https://upstash.com
# -------------------------------------------------------------
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# -------------------------------------------------------------
# Application
# In production, set NODE_ENV to "production" (auto-set by Vercel)
# -------------------------------------------------------------
NODE_ENV="development"
