# =============================================================
# Sales Portal - Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored.
# This file (.env.example) IS committed — keep it secret-free.
# =============================================================

# -------------------------------------------------------------
# Database (Neon PostgreSQL or any Postgres)
# Get connection string from: https://neon.tech
# -------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# -------------------------------------------------------------
# JWT Authentication
# Generate with: openssl rand -base64 32
# Must be at least 32 characters for security
# -------------------------------------------------------------
JWT_SECRET="your-jwt-secret-at-least-32-chars-long"
NEXTAUTH_SECRET="your-nextauth-secret-at-least-32-chars-long"

# -------------------------------------------------------------
# Email Service (Resend - https://resend.com)
# EMAIL_FROM must be a verified sender domain in Resend
# -------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="receipt@yourdomain.com"

# -------------------------------------------------------------
# -------------------------------------------------------------
# Receipt Storage (Supabase - https://supabase.com)
# Required for PDF receipt upload/storage feature
# NEXT_PUBLIC_SUPABASE_URL: Project URL from Supabase dashboard
# SUPABASE_SERVICE_ROLE_KEY: Service role key (keep secret - server-side only)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# -------------------------------------------------------------
# Application
# In production, set NODE_ENV to "production" (auto-set by Vercel)
# -------------------------------------------------------------
NODE_ENV="development"
