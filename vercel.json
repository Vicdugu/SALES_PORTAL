{
  "buildCommand": "prisma generate && prisma migrate deploy && node prisma/seed.js && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/receipts/**/*.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/admin/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
