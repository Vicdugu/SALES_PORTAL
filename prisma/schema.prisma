// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ===== TENANT MODEL =====
model Store {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  address   String?
  phone     String?
  
  // Branding
  backgroundImage String? // Store wallpaper/background URL
  primaryColor   String   @default("#000000")
  secondaryColor String   @default("#ffffff")
  accentColor    String   @default("#0066cc")
  
  // Configuration
  currency  String   @default("USD")
  
  // Status
  isActive  Boolean  @default(true)
  isApproved Boolean @default(false)
  emailVerified Boolean @default(false)
  verificationCode String?
  verificationCodeExpiry DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  users     User[]
  orders    Order[]
  inventory InventoryItem[]
  staff     StaffMember[]
  notifications Notification[]
  auditLogs AuditLog[]
  adverts   Advert[]
  features  StoreFeature[]
  
  @@index([email])
}

// ===== USER MANAGEMENT =====
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  isActive  Boolean  @default(true)
  refreshTokenHash   String?
  refreshTokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  orders    Order[]
  auditLogs AuditLog[]
  
  @@index([storeId])
}

enum Role {
  STAFF      // Till operator
  KITCHEN    // Kitchen staff
  ADMIN      // Store admin
  SUPERADMIN // System superadmin
}

model StaffMember {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  phone     String?
  address   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, storeId])
  @@index([storeId])
}

// ===== ORDERS =====
model Order {
  id        String   @id @default(cuid())
  orderNumber String  // Human-readable order number
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  staffId   String?
  staff     User?    @relation(fields: [staffId], references: [id])
  
  status    OrderStatus @default(PENDING)
  
  items     OrderItem[]
  payments  PaymentRecord[] // Support for split payments (up to 2)
  
  subtotal  Float    @default(0)
  tax       Float    @default(0)
  total     Float    @default(0)
  
  paymentMethod String? // Kept for backward compatibility
  notes     String?
  printedForKitchen Boolean @default(false) // set when cashier manually prints order slip
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?
  refundedAt  DateTime?
  
  @@index([storeId])
  @@index([staffId])
  @@index([status])
  @@index([createdAt])
}

model PaymentRecord {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  paymentMethod String // CASH, TRANSFER, POS
  amount    Float
  sequence  Int      // 1 for first payment, 2 for second (max 2 payments per order)
  
  createdAt DateTime @default(now())
  
  @@unique([orderId, sequence]) // Max 2 payments per order
  @@index([orderId])
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  name      String
  quantity  Int
  unitPrice Float
  notes     String?
  
  @@index([orderId])
}

// ===== INVENTORY =====
model InventoryItem {
  id        String   @id @default(cuid())
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  name      String
  category  String   // e.g., "Food", "Drink", "Dessert"
  unitPrice Float    // Price for POS system
  quantity  Int      // Available quantity for POS
  unit      String   @default("pieces") // e.g., "kg", "liters", "pieces"
  currentStock Float @default(0)
  minimumStock Float @default(10)
  
  lastRestocked DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  usageHistory InventoryUsage[]
  
  @@unique([name, storeId])
  @@index([storeId])
  @@index([category])
}

model InventoryUsage {
  id        String   @id @default(cuid())
  
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  quantity  Float
  reason    String   // "ORDER", "ADJUSTMENT", "DAMAGE"
  
  createdAt DateTime @default(now())
  
  @@index([itemId])
}

// ===== NOTIFICATIONS =====
model Notification {
  id        String   @id @default(cuid())
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String
  link      String?                       // Optional navigation URL
  category  String   @default("order")   // "order"|"inventory"|"payment"|"system"

  createdAt DateTime @default(now())

  reads     NotificationRead[]
  
  @@index([storeId])
  @@index([createdAt])
}

/// Per-user read/dismissed state for a notification.
/// One row per (user, notification) pair — absent = unread, present = read, dismissedAt set = hidden.
model NotificationRead {
  id             String    @id @default(cuid())
  userId         String
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  readAt         DateTime  @default(now())
  dismissedAt    DateTime?              // set when user dismisses/clears

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([notificationId])
}

enum NotificationType {
  LOW_STOCK
  ORDER_READY
  ORDER_PENDING
  ORDER_IN_PROGRESS
  ORDER_COMPLETED
  SYSTEM_ALERT
  PAYMENT_ERROR
}

// ===== AUDIT LOGS =====
model AuditLog {
  id        String   @id @default(cuid())
  
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  action    String
  resource  String
  details   String?
  
  createdAt DateTime @default(now())
  
  @@index([storeId])
  @@index([userId])
  @@index([createdAt])
}

// ===== VERIFICATION ATTEMPTS (pre-auth audit log) =====
model VerificationAttempt {
  id          String   @id @default(cuid())
  email       String
  ipAddress   String?
  success     Boolean
  reason      String?  // 'SUCCESS' | 'INVALID_TOKEN' | 'EXPIRED' | 'ALREADY_VERIFIED' | 'RATE_LIMITED'
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ===== ADVERTS =====
model Advert {
  id        String   @id @default(cuid())
  
  title     String
  description String?
  imageUrl  String
  link      String?           // Optional clickable link
  caption   String?           // Text label/CTA
  
  storeId   String?           // Null = universal advert visible to all stores
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  isActive  Boolean  @default(true)
  order     Int      @default(0)  // Display order in panel
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([storeId])
  @@index([isActive])
  @@index([order])
}

// ===== FEATURE FLAGS =====
model StoreFeature {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  flagKey   String   // e.g. "enable_print_before_kitchen", "enable_split_payment"
  enabled   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, flagKey])
  @@index([storeId])
}

